# NoveltySkill — environment variable template
#
# Copy this file to .env and fill in your values. .env is gitignored;
# this template is committed so others know which env vars to set.
#
#   cp .env.template .env
#   # then edit .env with your real values
#   set -a; source .env; set +a   # load into current shell

# ----- Required for the lit-search sub-skill (Phase 0 + Phase 3.1) -----

# OpenReview connector — needed to retrieve in-review submissions
OPENREVIEW_USER=your_openreview_email@example.com
OPENREVIEW_PASS=your_openreview_password


# ----- Optional but recommended -----

# OpenAlex polite-pool: real email in User-Agent gets 10 req/s vs 1 anonymous.
# Not authentication; just friendly identification per OpenAlex API guidelines.
OPENALEX_MAILTO=your_email@example.com

# OpenAlex premium API key (higher rate; optional, polite-pool also works without).
OPENALEX_API_KEY=your_openalex_key


# ----- Optional: backend CLI for non-host-LLM deployments -----
# When running outside Claude Code / Claude Desktop (e.g. Gemini, open-weights),
# set this to a CLI command that takes a stdin prompt (<<SYSTEM>>...<<USER>>...)
# and emits JSON on stdout. Used by the lit-search sub-skill for intent extraction
# + pattern tagging in Phase 0 and signature extraction in Phase 3.1.
#
# Example for Gemini:
#   NOVELTY_LLM_CLASSIFY_FAST_CMD='python wrappers/gemini.py --model gemini-2.5-flash'
# When unset (default for Claude Code), the orchestrator emits sentinel files
# and the host LLM handles those steps natively. See docs/USAGE.md.
# NOVELTY_LLM_CLASSIFY_FAST_CMD=
